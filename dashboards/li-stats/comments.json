    "urn:li:comment:(activity:7470539309444657152,7471134804680364032)": {
      "comment_urn": "urn:li:comment:(activity:7470539309444657152,7471134804680364032)",
      "commented_at": "2026-06-12T09:42:24Z",
      "verb": "commented",
      "text": "This pulls me back to the experience with a self-hosted GenAI for German banking contracts, far smaller than the general-purpose models that arrived later. On any generic benchmark, it would have looked unremarkable, yet in the exact spot it had to run, it outperformed the much bigger system for a couple of years. Capability on generic tasks told us almost nothing about behavior in our harness, on our documents. So I read KiloBench as measuring the right unit.",
      "comment_author_name": "Peter Ovchynnikov",
      "comment_author_url": "https://www.linkedin.com/in/ovchyn",
      "post_urn": "urn:li:activity:7471134819586985984",
      "post_url": "https://www.linkedin.com/feed/update/urn:li:activity:7471134819586985984/",
