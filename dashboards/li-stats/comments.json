    "urn:li:comment:(activity:7472754904965644289,7475511815591051264)": {
      "comment_urn": "urn:li:comment:(activity:7472754904965644289,7475511815591051264)",
      "commented_at": "2026-06-24T11:35:05Z",
      "verb": "commented",
      "text": "The local-agent bit is the real one here. Once the thing runs on someone's laptop there's no cloud-side box to hide it in, and most tooling still pretends there is. We've sort of got a working AI now. The next year is about keeping it in check and figuring out what the guardrails even are. You just showed one of the more concrete examples of where this is actually heading. Thanks!",
      "comment_author_name": "Peter Ovchynnikov",
      "comment_author_url": "https://www.linkedin.com/in/ovchyn",
      "post_urn": "urn:li:activity:7475511841956360192",
      "post_url": "https://www.linkedin.com/feed/update/urn:li:activity:7475511841956360192/",
      "post_author_name": "Marc Brooker",
      "post_author_url": "https://www.linkedin.com/in/marc-brooker-b431772b",
      "permalink": "https://www.linkedin.com/feed/update/urn:li:activity:7475511841956360192/?commentUrn=urn%3Ali%3Acomment%3A%28activity%3A7472754904965644289%2C7475511815591051264%29",
      "weeks": {
        "2026-06-29": {
          "snapshot_at": "2026-06-29T06:36:48Z",
          "reactions": 0,
          "replies_count": 0,
          "impressions": 31
        },
        "2026-07-13": {
          "snapshot_at": "2026-07-16T18:16:24Z",
