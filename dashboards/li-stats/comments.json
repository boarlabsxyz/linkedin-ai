    "urn:li:comment:(activity:7483474666548977665,7483565320331268096)": {
      "comment_urn": "urn:li:comment:(activity:7483474666548977665,7483565320331268096)",
      "commented_at": "2026-07-16T16:56:50Z",
      "verb": "commented",
      "text": "That's also why I don't think A and B are the only ways out. Once regeneration is cheap, you don't need code to be understandable by humans at all, you need the spec to be.",
